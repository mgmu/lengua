<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SettingsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintEnd_toEndOf="@+id/textView3"
            app:layout_constraintStart_toEndOf="@+id/textView3">

            <Spinner
                android:id="@+id/choose_words_quantity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="44dp"
                android:layout_marginEnd="4dp"
                android:entries="@array/words_quantity"
                android:minHeight="48dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/choose_lesson_frequency" />

            <TextView
                android:id="@+id/textView2"
                android:layout_width="265dp"
                android:layout_height="23dp"
                android:layout_marginTop="68dp"
                android:text="@string/number_of_words_per_lesson"
                app:layout_constraintEnd_toStartOf="@+id/choose_words_quantity"
                app:layout_constraintHorizontal_bias="0.266"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView3" />

            <Spinner
                android:id="@+id/choose_lesson_frequency"
                android:layout_marginTop="70dp"
                android:layout_width="186dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:entries="@array/lessons_frequency"
                android:minHeight="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                tools:ignore="TouchTargetSizeCheck"
                tools:layout_editor_absoluteY="58dp" />

            <Button
                android:id="@+id/saveBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/save"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView2"
                app:layout_constraintVertical_bias="0.503" />

            <TextView
                android:id="@+id/textView3"
                android:layout_width="177dp"
                android:layout_height="24dp"
                android:text="@string/lessons_frequency"
                app:layout_constraintEnd_toStartOf="@+id/choose_lesson_frequency"
                app:layout_constraintStart_toStartOf="parent"
                tools:layout_editor_absoluteY="66dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</FrameLayout>